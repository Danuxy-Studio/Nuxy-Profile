<!-- Simple Toast -->
<div id="toast" class="fixed bottom-20 left-1/2 -translate-x-1/2 bg-gray-800/95 backdrop-blur text-white px-4 py-2 rounded-full text-sm hidden z-50">
    <i class="fas fa-check-circle text-green-400 mr-2"></i>
    <span>Disalin!</span>
</div>

<script>
    function showToast(msg, type = 'success') {
        const toast = document.getElementById('toast');
        const icon = type === 'success' ? 'fa-check-circle text-green-400' : 'fa-exclamation-circle text-red-400';
        toast.innerHTML = `<i class="fas ${icon} mr-2"></i>${msg}`;
        toast.classList.remove('hidden');
        setTimeout(() => toast.classList.add('hidden'), 2000);
    }
    
    function copyText(text) {
        navigator.clipboard.writeText(text);
        showToast('Copied: ' + text);
    }
</script>