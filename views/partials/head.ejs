<style>
    * {
        font-family: 'Inter', sans-serif;
        -webkit-tap-highlight-color: transparent;
    }
    
    /* Pastikan background selalu gelap */
    body {
        background: linear-gradient(180deg, #0a0a14 0%, #0f0f1a 50%, #0a0a14 100%);
        min-height: 100vh;
        color: #e5e7eb;
    }
    
    /* Smooth transitions untuk semua elemen interaktif */
    a, button, .glass-card, .btn-primary {
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    /* Hover scale effect yang smooth */
    .hover-scale {
        transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    /* Page transition */
    .page-transition {
        transition: opacity 0.2s ease-out;
    }
    
    /* Smooth scroll behavior */
    html {
        scroll-behavior: smooth;
    }
    
    /* Header blur effect yang smooth */
    .backdrop-blur-md {
        backdrop-filter: blur(12px);
        transition: backdrop-filter 0.3s ease;
    }
    
    /* PRELOADER - Hilangkan glitch putih */
    .preloader {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background: linear-gradient(135deg, #0a0a14 0%, #0f0f1a 50%, #0a0a14 100%);
        z-index: 9999;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: opacity 0.5s ease, visibility 0.5s ease;
    }
    
    .preloader.hide {
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
    }
    
    /* Loader Animation */
    .loader {
        width: 60px;
        height: 60px;
        position: relative;
    }
    
    .loader .cube {
        position: absolute;
        width: 25px;
        height: 25px;
        background: linear-gradient(135deg, #8B5CF6, #7C3AED);
        border-radius: 6px;
        animation: cubeMove 1.8s infinite ease-in-out;
    }
    
    .loader .cube1 {
        top: 0;
        left: 0;
        animation-delay: 0s;
    }
    
    .loader .cube2 {
        top: 0;
        right: 0;
        animation-delay: 0.3s;
    }
    
    .loader .cube3 {
        bottom: 0;
        left: 0;
        animation-delay: 0.6s;
    }
    
    .loader .cube4 {
        bottom: 0;
        right: 0;
        animation-delay: 0.9s;
    }
    
    @keyframes cubeMove {
        0%, 100% {
            transform: scale(1);
            opacity: 1;
        }
        25% {
            transform: scale(1.2);
            opacity: 0.8;
        }
        50% {
            transform: scale(0.8);
            opacity: 0.5;
        }
        75% {
            transform: scale(1.1);
            opacity: 0.7;
        }
    }
    
    /* Skeleton Loading */
    .skeleton {
        background: linear-gradient(110deg, rgba(30, 27, 46, 0.6) 8%, rgba(45, 40, 60, 0.8) 18%, rgba(30, 27, 46, 0.6) 33%);
        background-size: 200% 100%;
        animation: skeletonWave 1.5s linear infinite;
        border-radius: 16px;
    }
    
    @keyframes skeletonWave {
        0% {
            background-position: 200% 0;
        }
        100% {
            background-position: -200% 0;
        }
    }
    
    /* Skeleton Variants */
    .skeleton-avatar {
        width: 112px;
        height: 112px;
        border-radius: 50%;
    }
    
    .skeleton-title {
        width: 180px;
        height: 28px;
        border-radius: 8px;
        margin: 0 auto;
    }
    
    .skeleton-bio {
        width: 250px;
        height: 16px;
        border-radius: 6px;
        margin: 8px auto 0;
    }
    
    .skeleton-link {
        width: 100%;
        height: 70px;
        border-radius: 20px;
    }
    
    .skeleton-card {
        width: 100%;
        height: 180px;
        border-radius: 20px;
    }
    
    /* Content wrapper - initial hide until loaded */
    .content-wrapper {
        opacity: 0;
        transition: opacity 0.2s ease;
    }
    
    .content-wrapper.loaded {
        opacity: 1;
    }
    
    /* Card Glass Effect */
    .glass-card {
        background: rgba(18, 18, 28, 0.85);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(139, 92, 246, 0.15);
        border-radius: 20px;
    }
    
    .glass-card:hover {
        background: rgba(18, 18, 28, 0.95);
        border-color: rgba(139, 92, 246, 0.4);
        transform: translateY(-2px);
        box-shadow: 0 8px 32px rgba(139, 92, 246, 0.1);
    }
    
    .gradient-text {
        background: linear-gradient(135deg, #c084fc, #a78bfa, #8b5cf6);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }
    
    .btn-primary {
        background: linear-gradient(135deg, #8B5CF6, #7C3AED);
        transition: all 0.2s ease;
    }
    
    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(139, 92, 246, 0.3);
    }
    
    .btn-primary:active {
        transform: scale(0.98);
    }
    
    .big-tap {
        min-height: 52px;
        cursor: pointer;
    }
    
    ::-webkit-scrollbar {
        width: 4px;
    }
    ::-webkit-scrollbar-track {
        background: #1a1a2e;
    }
    ::-webkit-scrollbar-thumb {
        background: #8B5CF6;
        border-radius: 4px;
    }
    ::-webkit-scrollbar-corner {
        background: #0a0a14;
    }
    
    /* Responsive untuk desktop */
    @media (min-width: 768px) {
        main {
            max-width: 1200px !important;
            margin-left: auto !important;
            margin-right: auto !important;
        }
        
        .glass-card {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        
        .glass-card:hover {
            transform: translateY(-4px);
            border-color: rgba(139, 92, 246, 0.5);
            box-shadow: 0 12px 40px rgba(139, 92, 246, 0.15);
        }
    }
    
    /* ========== ANIMATIONS ========== */
    
    @keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    
    .animate-fade-up {
        animation: fadeInUp 0.5s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    }
    
    @keyframes fadeIn {
        from { opacity: 0; }
        to { opacity: 1; }
    }
    
    .animate-fade {
        animation: fadeIn 0.4s ease forwards;
    }
    
    @keyframes scalePop {
        0% { transform: scale(0.9); opacity: 0; }
        80% { transform: scale(1.02); }
        100% { transform: scale(1); opacity: 1; }
    }
    
    .animate-pop {
        animation: scalePop 0.3s cubic-bezier(0.34, 1.2, 0.64, 1) forwards;
    }
    
    @keyframes glowPulse {
        0%, 100% { 
            box-shadow: 0 0 5px rgba(139, 92, 246, 0.3);
            border-color: rgba(139, 92, 246, 0.3);
        }
        50% { 
            box-shadow: 0 0 20px rgba(139, 92, 246, 0.6);
            border-color: rgba(139, 92, 246, 0.8);
        }
    }
    
    .animate-glow {
        animation: glowPulse 2s ease-in-out infinite;
    }
    
    @keyframes bounce {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-10px); }
    }
    
    .animate-bounce {
        animation: bounce 1s cubic-bezier(0.4, 0, 0.2, 1) infinite;
    }
    
    @keyframes float {
        0%, 100% { transform: translateY(0px); }
        50% { transform: translateY(-8px); }
    }
    
    .animate-float {
        animation: float 3s ease-in-out infinite;
    }
    
    @keyframes pulseRing {
        0% {
            box-shadow: 0 0 0 0 rgba(139, 92, 246, 0.4);
        }
        70% {
            box-shadow: 0 0 0 15px rgba(139, 92, 246, 0);
        }
        100% {
            box-shadow: 0 0 0 0 rgba(139, 92, 246, 0);
        }
    }
    
    .animate-pulse-ring {
        animation: pulseRing 1.5s ease infinite;
    }
    
    @keyframes slideInRight {
        from {
            opacity: 0;
            transform: translateX(30px);
        }
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }
    
    .animate-slide-right {
        animation: slideInRight 0.4s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    }
    
    @keyframes slideInLeft {
        from {
            opacity: 0;
            transform: translateX(-30px);
        }
        to {
            opacity: 1;
            transform: translateX(0);
        }
    }
    
    .animate-slide-left {
        animation: slideInLeft 0.4s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    }
    
    .stagger-item {
        opacity: 0;
        animation: fadeInUp 0.4s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    }
    
    .hover-scale {
        transition: transform 0.2s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    .hover-scale:hover {
        transform: scale(1.02);
    }
    
    .hover-scale:active {
        transform: scale(0.98);
    }
    
    @keyframes rotate {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }
    
    .animate-rotate {
        animation: rotate 1s linear infinite;
    }
    
    @keyframes countdownPulse {
        0%, 100% { transform: scale(1); }
        50% { transform: scale(1.1); }
    }
    
    .countdown-number {
        animation: countdownPulse 0.5s ease infinite;
    }
    
    @keyframes downloadReady {
        0% { transform: scale(1); }
        50% { transform: scale(1.05); box-shadow: 0 0 30px rgba(139,92,246,0.8); }
        100% { transform: scale(1); }
    }
    
    .ready-animation {
        animation: downloadReady 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    /* Nav link underline animation */
    .nav-link {
        position: relative;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    
    .nav-link::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 50%;
        width: 0;
        height: 2px;
        background: linear-gradient(90deg, #8B5CF6, #7C3AED);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        transform: translateX(-50%);
        border-radius: 2px;
    }
    
    .nav-link:hover::after {
        width: 80%;
    }
    
    /* Toast animation */
    @keyframes slideInToast {
        from {
            transform: translateX(100%);
            opacity: 0;
        }
        to {
            transform: translateX(0);
            opacity: 1;
        }
    }
    
    .toast-show {
        animation: slideInToast 0.3s cubic-bezier(0.4, 0, 0.2, 1) forwards;
    }
</style>

<!-- Global helper functions -->
<script>
    // Toast notification
    function showToast(message, type = 'success') {
        const existingToast = document.getElementById('globalToast');
        if (existingToast) existingToast.remove();
        
        const toast = document.createElement('div');
        toast.id = 'globalToast';
        toast.className = `fixed top-4 right-4 z-50 px-4 py-3 rounded-xl shadow-lg flex items-center gap-2 toast-show ${
            type === 'success' ? 'bg-emerald-500/90 text-white' : 'bg-red-500/90 text-white'
        }`;
        
        const icon = type === 'success' ? 'fa-check-circle' : 'fa-exclamation-circle';
        toast.innerHTML = `<i class="fas ${icon}"></i><span class="text-sm">${message}</span>`;
        document.body.appendChild(toast);
        
        setTimeout(() => {
            toast.style.opacity = '0';
            toast.style.transform = 'translateX(100%)';
            toast.style.transition = 'all 0.3s ease';
            setTimeout(() => toast.remove(), 300);
        }, 3000);
    }
    
    // Copy text helper
    function copyText(text) {
        navigator.clipboard.writeText(text);
        showToast(`Copied: ${text}`);
    }
    
    // Smooth page transitions
    document.addEventListener('DOMContentLoaded', () => {
        // Fade in body
        document.body.style.opacity = '0';
        setTimeout(() => {
            document.body.style.opacity = '1';
            document.body.style.transition = 'opacity 0.3s ease';
        }, 50);
        
        // Add transition to internal links (kecuali yang punya class no-transition)
        const links = document.querySelectorAll('a[href^="/"]');
        links.forEach(link => {
            if (link.hostname !== window.location.hostname) return;
            if (link.target === '_blank') return;
            if (link.href.includes('#') || link.href.includes('javascript:')) return;
            if (link.classList.contains('no-transition')) return;
            
            link.addEventListener('click', (e) => {
                e.preventDefault();
                const targetUrl = link.href;
                document.body.style.opacity = '0';
                document.body.style.transition = 'opacity 0.2s ease';
                setTimeout(() => {
                    window.location.href = targetUrl;
                }, 200);
            });
        });
    });
    
    // Preloader hide
    window.addEventListener('load', () => {
        const preloader = document.getElementById('globalPreloader');
        if (preloader) {
            setTimeout(() => {
                preloader.classList.add('hide');
                setTimeout(() => {
                    if (preloader) preloader.style.display = 'none';
                }, 500);
            }, 300);
        }
    });
    
    // Fallback preloader hide
    setTimeout(() => {
        const preloader = document.getElementById('globalPreloader');
        if (preloader && !preloader.classList.contains('hide')) {
            preloader.classList.add('hide');
            setTimeout(() => {
                if (preloader) preloader.style.display = 'none';
            }, 500);
        }
    }, 3000);
</script>