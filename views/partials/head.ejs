<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><%= typeof title !== 'undefined' ? title + ' - ' : '' %>Nuxy MC</title>

<link rel="icon" type="image/png" href="<%= typeof profile !== 'undefined' && profile.avatar_url ? profile.avatar_url : '/img/avatar.png' %>">

<script src="https://cdn.tailwindcss.com"></script>
<script>
    tailwind.config = {
        theme: {
            extend: {
                colors: {
                    primary: { DEFAULT: '#8B5CF6', dark: '#7C3AED' }
                }
            }
        }
    }
</script>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

<style>
    * { font-family: 'Inter', sans-serif; margin: 0; padding: 0; box-sizing: border-box; }
    
    body {
        background: linear-gradient(135deg, #0a0a14 0%, #111827 30%, #0f1724 60%, #0a0a14 100%);
        min-height: 100vh;
        color: #e5e7eb;
    }
    
    body::before {
        content: '';
        position: fixed; top: 0; left: 0; right: 0; bottom: 0;
        background-image: 
            radial-gradient(circle at 20% 50%, rgba(139,92,246,0.05) 0%, transparent 50%),
            radial-gradient(circle at 80% 20%, rgba(139,92,246,0.03) 0%, transparent 50%),
            radial-gradient(circle at 50% 80%, rgba(124,58,237,0.04) 0%, transparent 50%);
        pointer-events: none; z-index: 0;
    }
    
    main { position: relative; z-index: 1; }
    
    .glass-card {
        background: rgba(30,27,46,0.6);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(139,92,246,0.15);
        transition: all 0.3s ease;
    }
    .glass-card:hover {
        background: rgba(30,27,46,0.8);
        border-color: rgba(139,92,246,0.3);
        box-shadow: 0 8px 32px rgba(139,92,246,0.1);
    }
    
    .gradient-text {
        background: linear-gradient(135deg, #a78bfa, #8b5cf6, #7c3aed);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }
    
    .btn-primary {
        background: linear-gradient(135deg, #8B5CF6, #7C3AED);
        transition: all 0.3s ease;
    }
    .btn-primary:hover {
        background: linear-gradient(135deg, #7C3AED, #6D28D9);
        transform: translateY(-1px);
        box-shadow: 0 8px 20px rgba(139,92,246,0.3);
    }
    
    ::-webkit-scrollbar { width: 6px; }
    ::-webkit-scrollbar-track { background: #0a0a14; }
    ::-webkit-scrollbar-thumb { background: rgba(139,92,246,0.3); border-radius: 3px; }
    ::selection { background: rgba(139,92,246,0.3); color: white; }
    html { scroll-behavior: smooth; }
    input:focus, textarea:focus, select:focus { outline: none; }
</style>