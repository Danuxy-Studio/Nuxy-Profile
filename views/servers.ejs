<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/head') %>
    <style>
        html, body, #skeleton {
            background: linear-gradient(180deg, #0a0a14 0%, #0f0f1a 50%, #0a0a14 100%);
            min-height: 100vh;
        }
        body { margin: 0; padding: 0; }
        .skeleton { background: linear-gradient(110deg, #11111a 8%, #1a1a2a 18%, #11111a 33%); background-size: 200% 100%; }
    </style>
</head>
<body style="background: linear-gradient(180deg, #0a0a14 0%, #0f0f1a 50%, #0a0a14 100%);">
    <%- include('partials/preloader') %>
    <%- include('partials/header') %>
    
    <main class="max-w-md mx-auto px-4 py-4">
        <div id="skeleton" style="background: transparent;">
            <div class="skeleton skeleton-title w-48 mb-2"></div>
            <div class="skeleton w-64 h-4 mb-6"></div>
            <div class="skeleton h-40 w-full rounded-xl mb-5"></div>
            <div class="space-y-4">
                <div class="skeleton skeleton-card h-64"></div>
                <div class="skeleton skeleton-card h-64"></div>
            </div>
        </div>
        
        <div id="content" class="content-wrapper" style="display: none;">
            <div class="mb-6 animate-fade-up">
                <h1 class="text-2xl font-bold gradient-text"><i class="fas fa-server mr-2"></i> Minecraft Servers</h1>
                <p class="text-gray-400 text-sm mt-1"><i class="fas fa-fingerprint mr-1"></i> Tap IP untuk copy, langsung paste di Minecraft!</p>
            </div>

            <!-- CARA JOIN SERVER -->
            <div class="glass-card p-4 mb-5 animate-pop">
                <div class="flex items-center gap-2 mb-3">
                    <div class="w-8 h-8 rounded-lg bg-purple-500/20 flex items-center justify-center">
                        <i class="fas fa-question-circle text-purple-400 text-sm"></i>
                    </div>
                    <p class="text-white font-semibold text-sm"><i class="fas fa-book-open mr-1"></i> Cara Join Server:</p>
                </div>
                <ol class="text-gray-300 text-xs space-y-2">
                    <li class="flex items-start gap-2">
                        <span class="w-5 h-5 rounded-full bg-purple-500/20 text-purple-400 text-xs flex items-center justify-center flex-shrink-0 mt-0.5"><i class="fas fa-fingerprint text-[10px]"></i></span>
                        <span>Tap IP server di bawah (otomatis copy)</span>
                    </li>
                    <li class="flex items-start gap-2">
                        <span class="w-5 h-5 rounded-full bg-purple-500/20 text-purple-400 text-xs flex items-center justify-center flex-shrink-0 mt-0.5"><i class="fas fa-cube text-[10px]"></i></span>
                        <span>Buka Minecraft</span>
                    </li>
                    <li class="flex items-start gap-2">
                        <span class="w-5 h-5 rounded-full bg-purple-500/20 text-purple-400 text-xs flex items-center justify-center flex-shrink-0 mt-0.5"><i class="fas fa-plus text-[10px]"></i></span>
                        <span>Pilih Multiplayer → Add Server</span>
                    </li>
                    <li class="flex items-start gap-2">
                        <span class="w-5 h-5 rounded-full bg-purple-500/20 text-purple-400 text-xs flex items-center justify-center flex-shrink-0 mt-0.5"><i class="fas fa-paste text-[10px]"></i></span>
                        <span>Tap & hold kolom IP → Paste</span>
                    </li>
                    <li class="flex items-start gap-2">
                        <span class="w-5 h-5 rounded-full bg-green-500/20 text-green-400 text-xs flex items-center justify-center flex-shrink-0 mt-0.5"><i class="fas fa-check text-[10px]"></i></span>
                        <span>Save & Join! <i class="fas fa-rocket text-green-400"></i></span>
                    </li>
                </ol>
            </div>

            <% if (servers && servers.length > 0) { %>
                <div class="space-y-4">
                    <% servers.forEach(function(server, idx) { %>
                        <div class="glass-card p-5 stagger-item" style="animation-delay: <%= 0.1 * idx %>s">
                            <div class="flex items-center gap-3 mb-4">
                                <div class="w-10 h-10 rounded-xl bg-purple-500/20 flex items-center justify-center animate-pulse-ring">
                                    <i class="fas fa-server text-purple-400"></i>
                                </div>
                                <h2 class="text-white font-bold text-lg"><%= server.name %></h2>
                            </div>
                            
                            <div class="space-y-3">
                                <% if (server.has_java) { %>
                                    <div class="bg-gray-800/50 rounded-xl p-3 hover:bg-gray-800/70 transition">
                                        <div class="flex items-center gap-2 mb-2">
                                            <i class="fab fa-java text-orange-400"></i>
                                            <span class="text-white font-medium text-sm">Java Edition</span>
                                        </div>
                                        <div class="flex items-center justify-between bg-gray-900/50 rounded-lg p-3 big-tap hover:bg-gray-900/70 transition-all active:scale-[0.98]" 
                                             onclick="copyText('<%= server.java_ip %>')">
                                            <code class="text-purple-400 font-mono text-sm"><%= server.java_ip %></code>
                                            <i class="fas fa-copy text-gray-500 hover:text-purple-400 transition"></i>
                                        </div>
                                    </div>
                                <% } %>
                                
                                <% if (server.has_bedrock) { %>
                                    <div class="bg-gray-800/50 rounded-xl p-3 hover:bg-gray-800/70 transition">
                                        <div class="flex items-center gap-2 mb-2">
                                            <i class="fas fa-cube text-blue-400"></i>
                                            <span class="text-white font-medium text-sm">Bedrock Edition</span>
                                        </div>
                                        <div class="space-y-2">
                                            <div class="flex items-center justify-between bg-gray-900/50 rounded-lg p-3 big-tap hover:bg-gray-900/70 transition-all active:scale-[0.98]" 
                                                 onclick="copyText('<%= server.bedrock_ip %>')">
                                                <div>
                                                    <p class="text-gray-500 text-[10px]"><i class="fas fa-network-wired mr-1"></i>IP Address</p>
                                                    <code class="text-purple-400 font-mono text-sm"><%= server.bedrock_ip %></code>
                                                </div>
                                                <i class="fas fa-copy text-gray-500 hover:text-purple-400 transition"></i>
                                            </div>
                                            <div class="flex items-center justify-between bg-gray-900/50 rounded-lg p-3 big-tap hover:bg-gray-900/70 transition-all active:scale-[0.98]" 
                                                 onclick="copyText('<%= server.bedrock_port %>')">
                                                <div>
                                                    <p class="text-gray-500 text-[10px]"><i class="fas fa-plug mr-1"></i>Port</p>
                                                    <code class="text-purple-400 font-mono text-sm"><%= server.bedrock_port %></code>
                                                </div>
                                                <i class="fas fa-copy text-gray-500 hover:text-purple-400 transition"></i>
                                            </div>
                                        </div>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    <% }); %>
                </div>
            <% } else { %>
                <div class="glass-card p-8 text-center animate-pop">
                    <i class="fas fa-server text-5xl text-gray-600 mb-3"></i>
                    <p class="text-gray-400">Belum ada server</p>
                    <p class="text-gray-600 text-sm"><i class="fas fa-clock mr-1"></i>Cek lagi nanti ya!</p>
                </div>
            <% } %>
        </div>
    </main>
    
    <%- include('partials/mobileNav') %>
    <%- include('partials/footer') %>
    
    <script>
        (function() {
            const skeleton = document.getElementById('skeleton');
            const content = document.getElementById('content');
            if (skeleton && content) {
                setTimeout(function() {
                    skeleton.style.opacity = '0';
                    skeleton.style.transition = 'opacity 0.2s';
                    setTimeout(function() {
                        skeleton.style.display = 'none';
                        content.style.display = 'block';
                        setTimeout(function() { content.classList.add('loaded'); }, 20);
                    }, 200);
                }, 300);
            }
        })();
        
        function copyText(text) {
            navigator.clipboard.writeText(text);
            const toast = document.getElementById('toast') || (function() {
                const t = document.createElement('div');
                t.id = 'toast';
                t.className = 'fixed bottom-20 left-1/2 -translate-x-1/2 bg-gray-800/95 backdrop-blur text-white px-4 py-2 rounded-full text-sm z-50';
                document.body.appendChild(t);
                return t;
            })();
            toast.innerHTML = '<i class="fas fa-check-circle text-green-400 mr-2"></i> Copied: ' + text;
            toast.classList.remove('hidden');
            setTimeout(() => toast.classList.add('hidden'), 2000);
        }
    </script>
</body>
</html>