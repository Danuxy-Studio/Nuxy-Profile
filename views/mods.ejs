<!DOCTYPE html>
<html lang="id">
<head>
    <%- include('partials/head') %>
    <style>
        html, body, #skeleton {
            background: linear-gradient(180deg, #0a0a14 0%, #0f0f1a 50%, #0a0a14 100%);
            min-height: 100vh;
        }
        body { margin: 0; padding: 0; }
        .skeleton { background: linear-gradient(110deg, #11111a 8%, #1a1a2a 18%, #11111a 33%); background-size: 200% 100%; }
    </style>
</head>
<body style="background: linear-gradient(180deg, #0a0a14 0%, #0f0f1a 50%, #0a0a14 100%);">
    <%- include('partials/preloader') %>
    <%- include('partials/header') %>
    
    <main class="max-w-md mx-auto px-4 py-4">
        <div id="skeleton" style="background: transparent;">
            <div class="skeleton skeleton-title w-40 mb-2"></div>
            <div class="skeleton w-64 h-4 mb-6"></div>
            <div class="space-y-4">
                <div class="skeleton skeleton-card h-44"></div>
                <div class="skeleton skeleton-card h-44"></div>
                <div class="skeleton skeleton-card h-44"></div>
            </div>
        </div>
        
        <div id="content" class="content-wrapper" style="display: none;">
            <div class="mb-6 animate-fade-up">
                <h1 class="text-2xl font-bold gradient-text"><i class="fas fa-cubes mr-2"></i> Modpacks</h1>
                <p class="text-gray-400 text-sm mt-1"><i class="fas fa-download mr-1"></i> Klik download, tunggu 5 detik, selesai!</p>
            </div>

            <% if (mods && mods.length > 0) { %>
                <div class="space-y-4">
                    <% mods.forEach(function(mod, idx) { %>
                        <div class="glass-card overflow-hidden stagger-item" style="animation-delay: <%= 0.08 * idx %>s">
                            <div class="p-4 border-b border-purple-500/10">
                                <div class="flex items-start justify-between">
                                    <div class="flex-1">
                                        <h2 class="text-white font-bold text-lg"><%= mod.name %></h2>
                                        <div class="flex items-center gap-2 mt-1">
                                            <span class="text-xs bg-purple-500/20 text-purple-300 px-2 py-0.5 rounded-full">
                                                <i class="fab fa-java mr-1"></i>MC <%= mod.mc_version %>
                                            </span>
                                            <span class="text-xs text-gray-500">
                                                <i class="far fa-calendar mr-1"></i><%= mod.release_date %>
                                            </span>
                                        </div>
                                    </div>
                                    <div class="w-10 h-10 rounded-xl bg-purple-500/20 flex items-center justify-center animate-float">
                                        <i class="fas fa-cube text-purple-400"></i>
                                    </div>
                                </div>
                            </div>
                            
                            <div class="p-4">
                                <p class="text-gray-300 text-sm mb-4"><%= mod.description %></p>
                                
                                <a href="/download/<%= mod.id %>" 
                                   class="btn-primary w-full py-4 rounded-xl text-white font-semibold text-center flex items-center justify-center gap-2 big-tap hover:scale-[1.02] active:scale-[0.98] transition-all duration-200">
                                    <i class="fas fa-download"></i>
                                    Download Modpack
                                </a>
                            </div>
                        </div>
                    <% }); %>
                </div>
            <% } else { %>
                <div class="glass-card p-8 text-center animate-pop">
                    <i class="fas fa-cubes text-5xl text-gray-600 mb-3"></i>
                    <p class="text-gray-400">Belum ada modpack</p>
                    <p class="text-gray-600 text-sm"><i class="fas fa-clock mr-1"></i>Cek lagi nanti ya!</p>
                </div>
            <% } %>
        </div>
    </main>
    
    <%- include('partials/mobileNav') %>
    <%- include('partials/footer') %>
    
    <script>
        (function() {
            const skeleton = document.getElementById('skeleton');
            const content = document.getElementById('content');
            if (skeleton && content) {
                setTimeout(function() {
                    skeleton.style.opacity = '0';
                    skeleton.style.transition = 'opacity 0.2s';
                    setTimeout(function() {
                        skeleton.style.display = 'none';
                        content.style.display = 'block';
                        setTimeout(function() { content.classList.add('loaded'); }, 20);
                    }, 200);
                }, 300);
            }
        })();
    </script>
</body>
</html>